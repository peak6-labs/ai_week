# Kalshi credentials — COPY this file to `.env` and fill in YOUR OWN values.
# `.env` and everything in secrets/ are gitignored. Never commit real values.
#
# Each teammate creates their OWN API key in the Kalshi portal (same account,
# separate keys) and points these vars at their own local .pem file.

# Which environment the code talks to: "demo" or "prod"
KALSHI_ENV=demo

# --- Demo account (paper trading) ---
KALSHI_DEMO_KEY_ID=your-demo-api-key-id-uuid
KALSHI_DEMO_PRIVATE_KEY_PATH=secrets/kalshi-demo-key.pem

# --- Production account (REAL money — the $500) ---
KALSHI_PROD_KEY_ID=your-prod-api-key-id-uuid
KALSHI_PROD_PRIVATE_KEY_PATH=secrets/kalshi-key.pem
